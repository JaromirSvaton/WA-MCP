{
  "name": "wa-mcp",
  "version": "1.0.0",
  "description": "WhatsApp MCP server for Claude Desktop (Baileys, no browser)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "login": "npm run build && node dist/login.js",
    "logout": "npm run build && node dist/login.js --logout",
    "print-config": "node dist/print-config.js",
    "setup": "npm install && npm run build && node dist/print-config.js",
    "start": "node dist/index.js"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@whiskeysockets/baileys": "^6.7.23",
    "better-sqlite3": "^12.11.1",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
